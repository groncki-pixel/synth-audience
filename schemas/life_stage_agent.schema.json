{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Life Stage Agent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "life_stage",
    "age",
    "gender",
    "metadata"
  ],
  "properties": {
    "agent_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique agent identifier (UUID).",
      "x-latent": false,
      "x-source": "generated"
    },
    "life_stage": {
      "type": "string",
      "enum": ["child", "adolescent", "young_adult", "young_professional", "adult", "older_adult"],
      "description": "Canonical life stage bucket.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "household_id": {
      "oneOf": [
        { "type": "string", "format": "uuid" },
        { "type": "null" }
      ],
      "description": "Household grouping UUID or null.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "age": {
      "type": "integer",
      "minimum": 0,
      "maximum": 120,
      "description": "Agent age in years.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "gender": {
      "type": "string",
      "enum": ["male", "female", "nonbinary", "other", "unknown"],
      "description": "Self-reported gender.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "race_ethnicity": {
      "type": ["string", "null"],
      "description": "Standardized race/ethnicity code (use project codebook); null if unknown.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "education_level": {
      "type": "string",
      "enum": ["none", "primary", "secondary", "some_college", "bachelors", "postgrad", "unknown"],
      "description": "Highest completed education level.",
      "x-latent": false,
      "x-source": "sampled"
    },
    "ideology_score": {
      "oneOf": [
        { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        { "type": "null" }
      ],
      "description": "Continuous ideology score in [0,1]; null if latent.",
      "x-latent": true,
      "x-source": "inherited|donor|sampled"
    },
    "big5": {
      "type": ["object", "null"],
      "description": "Big Five personality dimensions (0-1) or null if latent.",
      "x-latent": true,
      "x-source": "donor|sampled|inherited",
      "properties": {
        "openness": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "conscientiousness": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "extraversion": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "agreeableness": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "neuroticism": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "moral_foundations": {
      "type": ["object", "null"],
      "description": "Moral foundations (care, fairness, loyalty, authority, sanctity) each 0-1 or null.",
      "x-latent": true,
      "x-source": "donor|sampled|inherited",
      "properties": {
        "care": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "fairness": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "loyalty": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "authority": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] },
        "sanctity": { "oneOf": [{ "type": "number", "minimum": 0.0, "maximum": 1.0 }, { "type": "null" }] }
      },
      "additionalProperties": false
    },
    "media_autonomy": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Probability agent chooses media independently (0-1).",
      "x-latent": false,
      "x-source": "sampled|inherited"
    },
    "peer_influence_weight": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Weight of peer signals in decisions (0-1).",
      "x-latent": false,
      "x-source": "sampled|derived"
    },
    "parental_influence_weight": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Weight of parental/household signals in decisions (0-1).",
      "x-latent": false,
      "x-source": "sampled|derived"
    },
    "platform_usage": {
      "type": "object",
      "description": "Mapping of platform name to usage intensity (0-1). Platforms not present imply zero or missing.",
      "x-latent": false,
      "x-source": "sampled|inferred",
      "additionalProperties": {
        "type": "number",
        "minimum": 0.0,
        "maximum": 1.0
      }
    },
    "taste_vector": {
      "oneOf": [
        {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 128,
          "maxItems": 128,
          "description": "Fixed-length taste embedding (128 floats)."
        },
        { "type": "null" }
      ],
      "x-latent": true,
      "x-source": "donor|inherited|sampled"
    },
    "exposure_history": {
      "type": "array",
      "description": "Chronological exposures to content.",
      "items": {
        "type": "object",
        "required": ["content_id", "timestamp", "source"],
        "properties": {
          "content_id": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "source": { "type": "string" },
          "reaction": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      },
      "x-latent": false,
      "x-source": "runtime"
    },
    "memory_store": {
      "type": "array",
      "description": "Short text memory entries for LLM conditioning (most recent first).",
      "items": { "type": "string", "maxLength": 512 },
      "x-latent": false,
      "x-source": "runtime"
    },
    "virality_susceptibility": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Composite susceptibility score (derived).",
      "x-latent": false,
      "x-source": "derived"
    },
    "decision_rules": {
      "type": "object",
      "description": "Thresholds and parameters for watch/share decisions.",
      "x-latent": false,
      "x-source": "sampled|derived",
      "properties": {
        "watch_threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "share_threshold": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "reconsideration_window": { "type": "integer", "minimum": 0 },
        "decay_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "k_complex": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "description": "Provenance and reproducibility metadata.",
      "required": ["created_at", "created_by", "seed", "source_weights"],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "seed": { "type": ["integer", "string"] },
        "source_weights": {
          "type": "object",
          "description": "Mapping of data sources and their contribution weights.",
          "additionalProperties": {
            "oneOf": [
              { "type": "number" },
              { "type": "object", "properties": { "weight": { "type": "number" }, "donor_id": { "type": "string" } }, "additionalProperties": false }
            ]
          }
        },
        "notes": { "type": ["string", "null"] }
      },
      "additionalProperties": false,
      "x-latent": false,
      "x-source": "generated"
    }
  },
  "definitions": {
    "taste_vector": {
      "type": "array",
      "items": { "type": "number" },
      "minItems": 128,
      "maxItems": 128
    }
  },
  "examples": [
    {
      "agent_id": "00000000-0000-4000-8000-000000000001",
      "life_stage": "adolescent",
      "household_id": "11111111-1111-4111-8111-111111111111",
      "age": 14,
      "gender": "female",
      "race_ethnicity": "unknown",
      "education_level": "secondary",
      "ideology_score": null,
      "big5": {
        "openness": null,
        "conscientiousness": null,
        "extraversion": 0.72,
        "agreeableness": null,
        "neuroticism": 0.45
      },
      "moral_foundations": {
        "care": null,
        "fairness": null,
        "loyalty": null,
        "authority": null,
        "sanctity": null
      },
      "media_autonomy": 0.35,
      "peer_influence_weight": 0.8,
      "parental_influence_weight": 0.6,
      "platform_usage": { "tiktok": 0.9, "snapchat": 0.6, "youtube": 0.7 },
      "taste_vector": null,
      "exposure_history": [],
      "memory_store": [],
      "virality_susceptibility": 0.78,
      "decision_rules": { "watch_threshold": 0.45, "share_threshold": 0.6, "reconsideration_window": 7, "decay_rate": 0.12, "k_complex": 2 },
      "metadata": {
        "created_at": "2026-04-18T00:00:00Z",
        "created_by": "Copilot",
        "seed": 42,
        "source_weights": { "household": 0.9, "peer_cluster": 0.1 }
      }
    }
  ]
}
